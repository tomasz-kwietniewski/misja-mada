# Fundacja Misja MADA - konfiguracja serwera (Apache/LiteSpeed)

# Własna strona błędu 404 (ścieżka absolutna - działa spod dowolnego adresu)
ErrorDocument 404 /404.html

# Domena kanoniczna: misjamada.pl (bez www). Przekierowanie www -> bez www (301).
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.misjamada\.pl [NC]
RewriteRule ^(.*)$ https://misjamada.pl/$1 [R=301,L]

# Pliki uczestniczące w tłumaczeniu zmieniają się często. Domyślnie serwer cache'uje
# JS na 7 dni (max-age=604800) BEZ rewalidacji - przez co po aktualizacji słownika
# wracający użytkownik widzi starą wersję (nowe frazy zostają nieprzetłumaczone).
# Wymuszamy rewalidację (ETag/Last-Modified) przy każdym wejściu: gdy plik się nie
# zmienił -> 304 (tanie), gdy się zmienił -> świeża wersja od razu.
# (URL skryptów ma dodatkowo ?v=… - jednorazowo przełamuje już-zapisany 7-dniowy cache.)
#
# Reguła obejmuje NIE TYLKO słowniki: renderery i formularze też budują widoczny
# tekst, więc stary renderer + nowy słownik = połowicznie przetłumaczona strona
# (dokładnie ten przypadek: daty w archiwum). Wcześniej wzorzec łapał sam „i18n*",
# a renderery nie miały nawet ?v= - czyli mogły wisieć w cache 7 dni.
<IfModule mod_headers.c>
  <FilesMatch "(i18n(-dict(-fr)?)?|.*-render|adopcja-form|darowizna|newsletter|site-search|site-common|secure-form)\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # HTML też musi się rewalidować (audyt 2026-07-24): bez Cache-Control przeglądarka
  # cache'uje HTML heurystycznie (10% wieku pliku - godziny/dni) i po deployu serwuje
  # STARY HTML z NOWYMI skryptami no-cache. Taki skew realnie zepsuł modale po
  # wprowadzeniu site-common.js (stary HTML nie ładował nowego pliku). 304 jest tanie.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Nagłówki bezpieczeństwa (audyt 2026-07-24) ──
# Strona przyjmuje płatności - wymuszamy minimum branżowe:
#  - HSTS: przeglądarka wraca zawsze po HTTPS (6 mies.; bez includeSubDomains,
#    bo nie kontrolujemy ewentualnych przyszłych subdomen),
#  - nosniff: blokada zgadywania typu MIME (np. wykonanie uploadu jako skryptu),
#  - SAMEORIGIN: strona nie da się osadzić w cudzym iframe (clickjacking),
#  - Referrer-Policy: obce strony nie widzą pełnych URL-i (m.in. manage.php?token=...).
# Pełny CSP świadomie odłożony: wymagałby przebudowy inline skryptów i CDN (D3, fonty).
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=15552000"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Obrona w głąb: blokada dostępu z weba do danych, sekretów i logów ──
# Te katalogi mają też osobne .htaccess tworzone ręcznie na serwerze, ale tamte
# są niewersjonowane i mogą zniknąć przy odtworzeniu katalogu. Reguły poniżej są
# w repo i w deployu, więc stanowią trwałą, niezależną warstwę ochrony:
#  - data/   -> manifesty CMS + log notyfikacji PayU (z e-mailami) - czytane tylko
#               po stronie serwera, nigdy pobierane z przeglądarki (obrazy są w /uploads/),
#  - */secret/-> sekrety PayU/newsletter/panel (klucze, hasła, config bazy),
#  - *.log/*.sql -> ewentualne logi i zrzuty bazy.
RedirectMatch 403 ^/data(/|$)
RedirectMatch 403 /secret/
<FilesMatch "\.(log|sql)$">
  Require all denied
</FilesMatch>
